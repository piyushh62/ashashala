# AshaShala — Environment Variables
# Copy this file to .env and fill in all values
# NEVER commit .env to git (it's in .gitignore)

# =============================================================================
# REQUIRED — Application will crash on startup if any are missing
# =============================================================================

# Google AI Studio — https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# NVIDIA NGC — https://build.nvidia.com (single key for ALL NVIDIA models)
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Neon Postgres — https://neon.tech
# Format: postgresql+psycopg://USER:PASS@HOST/DB?sslmode=require
DATABASE_URL=postgresql+psycopg://user:pass@ep-xxx.us-east-1.aws.neon.tech/ashashala?sslmode=require

# Qdrant Cloud — https://cloud.qdrant.io
QDRANT_URL=https://xxx.us-east-1.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# Cloudflare R2 — https://dash.cloudflare.com
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=ashashala
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# JWT Secrets — Generate with: openssl rand -hex 32
JWT_SECRET=your_64_char_random_string_here
JWT_REFRESH_SECRET=your_different_64_char_random_string_here

# Super Admin — Seeded on first run
SUPER_ADMIN_EMAIL=admin@ashashala.org
SUPER_ADMIN_PASSWORD=your_secure_password_here

# CORS — Comma-separated origins (no trailing slashes)
ALLOWED_ORIGINS=http://localhost:5173,https://ashashala.vercel.app

# =============================================================================
# OPTIONAL — Set from Phase 1
# =============================================================================

# Sentry — https://sentry.io (free tier: 5k errors/month)
SENTRY_DSN=https://xxx@oxxx.ingest.sentry.io/xxx

# =============================================================================
# DEVELOPMENT OVERRIDES (optional)
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Disable external calls for local testing (true/false)
MOCK_EXTERNAL_SERVICES=false