# AshaShala Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# =============================================================================
# REQUIRED: LLM Providers
# =============================================================================
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Get from: https://build.nvidia.com/ (NGC API Key)
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# =============================================================================
# REQUIRED: Database (Neon Postgres)
# =============================================================================
# Get from: https://console.neon.tech/ (Connection string with pooling)
# Format: postgresql+asyncpg://user:pass@host/db?sslmode=require
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-1.aws.neon.tech/ashashala?sslmode=require

# =============================================================================
# REQUIRED: Vector Database (Qdrant Cloud)
# =============================================================================
# Get from: https://cloud.qdrant.io/ (Cluster URL and API Key)
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# =============================================================================
# REQUIRED: Object Storage
# =============================================================================
# Use either Cloudflare R2 or another S3-compatible provider such as Backblaze B2.
# If you use Cloudflare R2, fill the R2_* values and leave STORAGE_* empty.
# If you use another S3-compatible provider, fill the STORAGE_* values.
# Cloudflare R2 values:
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=ashashala-assets
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Generic S3-compatible values:
STORAGE_ENDPOINT_URL=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET_NAME=
STORAGE_PUBLIC_URL=
STORAGE_REGION=auto

# =============================================================================
# REQUIRED: Authentication
# =============================================================================
# Generate with: openssl rand -base64 48
JWT_SECRET=your_64_char_jwt_secret_here_minimum_32_chars
JWT_REFRESH_SECRET=your_64_char_refresh_secret_here_minimum_32_chars

# Super admin credentials for initial setup
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=secure_password_here

# =============================================================================
# REQUIRED: CORS
# =============================================================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com

# =============================================================================
# OPTIONAL: Observability
# =============================================================================
# Get from: https://sentry.io/ (Project DSN)
SENTRY_DSN=https://xxx@sentry.io/xxx

# =============================================================================
# OPTIONAL: Development
# =============================================================================
LOG_LEVEL=INFO
MOCK_EXTERNAL_SERVICES=false

# Timeouts (seconds)
GEMINI_TIMEOUT=30
NVIDIA_TIMEOUT=45
QDRANT_TIMEOUT=10
R2_TIMEOUT=60