    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-table": "^8.21.3",
    "cmdk": "^1.1.1",
    "i18next": "^26.3.6",
    "lucide-react": "^1.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.81.0",
